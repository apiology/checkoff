  sig { override.returns(::String) }
  def describe; end

  # pkg:gem/parlour#lib/parlour/types.rb:184
  sig { override.returns(::String) }
  def generate_rbi; end

  # pkg:gem/parlour#lib/parlour/types.rb:189
  sig { override.returns(::String) }

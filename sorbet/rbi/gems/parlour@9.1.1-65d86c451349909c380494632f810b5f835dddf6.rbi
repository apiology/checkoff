# pkg:gem/parlour#lib/parlour/types.rb:458
class Parlour::Types::Self < ::Parlour::Types::Type
  # pkg:gem/parlour#lib/parlour/types.rb:460
  sig { params(other: ::Object).returns(T::Boolean) }
